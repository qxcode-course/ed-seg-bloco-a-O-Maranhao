            "content": "package main\n\nimport \"fmt\"\n\ntype Gomo struct {\n\tx, y int\n}\n\nfunc main() {\n\tqtd := 0\n\tdir := \"\"\n\n\tfmt.Scan(&qtd, &dir)\n\tcobra := make([]Gomo, qtd)\n\tfor i := range cobra {\n\t\tfmt.Scan(&cobra[i].x, &cobra[i].y)\n\t}\n\n\tfor i := qtd - 1; i > 0; i-- {\n\t\tcobra[i] = cobra[i-1]\n\t}\n\tswitch dir {\n\tcase \"L\":\n\t\tcobra[0].x--\n\tcase \"R\":\n\t\tcobra[0].x++\n\tcase \"U\":\n\t\tcobra[0].y--\n\tcase \"D\":\n\t\tcobra[0].y++\n\t}\n\tfor _, gomo := range cobra {\n\t\tfmt.Printf(\"%v %v\\n\", gomo.x, gomo.y)\n\t}\n\n}\n",
